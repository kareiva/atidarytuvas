# SIP Configuration (using PJSUA2)
# Include port in SIP_PROXY if needed (e.g., sips.peoplefone.lt:5060)
SIP_PROXY=sip.example.com:5060
SIP_USERNAME=your_username
SIP_PASSWORD=your_password

# Phone numbers for different targets (in E.164 format recommended, e.g., +1234567890)
# Format: PHONE_NUMBER_<NAME>=<number>
# Each will be formatted as: sip:+1234567890@SIP_PROXY
# You can add as many targets as needed
PHONE_NUMBER_DOOR=+1234567890
PHONE_NUMBER_GATE=+0987654321
# PHONE_NUMBER_GARAGE=+1122334455

# Flask Configuration
FLASK_PORT=5000
FLASK_DEBUG=False

# Logging Configuration
# If not set or empty: ERROR (errors only - default)
# LOG_LEVEL options:
#   ERROR - Errors only (minimal output)
#   INFO  - Errors + informational messages (SIP events, registration, calls)
# LOG_LEVEL=INFO

# Call Configuration
# Seconds after the call is answered before auto-hangup (default: 10)
# HANGUP_TIMEOUT=10
