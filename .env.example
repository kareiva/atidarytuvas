# SIP Configuration (using PJSUA2)
# Include port in SIP_PROXY if needed (e.g., sips.peoplefone.lt:5060)
SIP_PROXY=sip.example.com:5060
SIP_USERNAME=your_username
SIP_PASSWORD=your_password

# GSM door opener phone number (in E.164 format recommended, e.g., +1234567890)
# Will be formatted as: sip:+1234567890@SIP_PROXY
PHONE_NUMBER=+1234567890

# Flask Configuration
FLASK_PORT=5000
FLASK_DEBUG=False
